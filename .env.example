# ----------------------------------------------------------------------------
# StoreX website — environment variables
# Copy this file to `.env.local` (for local dev) and fill in real values.
# On Vercel, set these in Project Settings → Environment Variables.
# ----------------------------------------------------------------------------

# SMTP transport for the contact form (app/api/contact/route.ts).
# Works with any SMTP provider (e.g. Gmail App Passwords, Mailgun, Postmark,
# SendGrid SMTP, Amazon SES, Resend SMTP, etc.).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use "true" for port 465 (implicit TLS), "false" for 587 (STARTTLS).
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# The "From" address shown on the email. Many providers require this to be a
# verified sender / the authenticated SMTP user.
CONTACT_FROM_EMAIL="StoreX Website <no-reply@lumora.com>"

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=sales@lumora.com
